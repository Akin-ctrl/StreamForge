{
  "gateway_id": "gateway-demo-01",
  "adapters": [
    {
      "adapter_id": "modbus-packaging-plc",
      "name": "Packaging Cell PLC",
      "adapter_type": "modbus_tcp",
      "config": {
        "host": "plant-simulator",
        "port": 15020,
        "unit_id": 1,
        "poll_interval_ms": 1000,
        "points": [
          {
            "point_name": "packaging_conveyor_speed",
            "memory_area": "holding_register",
            "address": 40001,
            "data_type": "uint16",
            "scale": 0.1,
            "unit": "m/min",
            "classification": "telemetry"
          },
          {
            "point_name": "packaging_motor_current",
            "memory_area": "holding_register",
            "address": 40002,
            "data_type": "uint16",
            "scale": 0.1,
            "unit": "A",
            "classification": "telemetry"
          },
          {
            "point_name": "packaging_bearing_temperature",
            "memory_area": "holding_register",
            "address": 40003,
            "data_type": "uint16",
            "scale": 0.1,
            "unit": "celsius",
            "classification": "telemetry"
          },
          {
            "point_name": "packaging_reject_count",
            "memory_area": "holding_register",
            "address": 40004,
            "data_type": "uint16",
            "unit": "count",
            "classification": "telemetry"
          },
          {
            "point_name": "packaging_motor_running",
            "memory_area": "coil",
            "address": 1,
            "data_type": "bool",
            "classification": "telemetry"
          },
          {
            "point_name": "packaging_jam_active",
            "memory_area": "coil",
            "address": 2,
            "data_type": "bool",
            "classification": "event",
            "event_type": "packaging_jam_state_change"
          }
        ],
        "output": {
          "kafka_bootstrap": "kafka:9092",
          "topic": "telemetry.raw",
          "events_topic": "events.raw",
          "asset_id": "packaging_cell_01"
        }
      }
    },
    {
      "adapter_id": "modbus-pump-skid-plc",
      "name": "Pump Skid PLC",
      "adapter_type": "modbus_tcp",
      "config": {
        "host": "plant-simulator",
        "port": 15021,
        "unit_id": 1,
        "poll_interval_ms": 1000,
        "points": [
          {
            "point_name": "pump_suction_pressure",
            "memory_area": "holding_register",
            "address": 40001,
            "data_type": "uint16",
            "scale": 0.01,
            "unit": "bar",
            "classification": "telemetry"
          },
          {
            "point_name": "pump_discharge_pressure",
            "memory_area": "holding_register",
            "address": 40002,
            "data_type": "uint16",
            "scale": 0.01,
            "unit": "bar",
            "classification": "telemetry"
          },
          {
            "point_name": "pump_flow_rate",
            "memory_area": "holding_register",
            "address": 40003,
            "data_type": "uint16",
            "scale": 0.1,
            "unit": "L/min",
            "classification": "telemetry"
          },
          {
            "point_name": "pump_vibration",
            "memory_area": "holding_register",
            "address": 40004,
            "data_type": "uint16",
            "scale": 0.01,
            "unit": "mm/s",
            "classification": "telemetry"
          },
          {
            "point_name": "pump_running",
            "memory_area": "coil",
            "address": 1,
            "data_type": "bool",
            "classification": "telemetry"
          },
          {
            "point_name": "pump_low_suction_active",
            "memory_area": "coil",
            "address": 2,
            "data_type": "bool",
            "classification": "event",
            "event_type": "pump_low_suction_state_change"
          }
        ],
        "output": {
          "kafka_bootstrap": "kafka:9092",
          "topic": "telemetry.raw",
          "events_topic": "events.raw",
          "asset_id": "pump_skid_01"
        }
      }
    },
