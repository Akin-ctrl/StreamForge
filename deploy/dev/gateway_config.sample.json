    },
    {
      "adapter_id": "rtu-remote-tank",
      "name": "Remote Tank RTU",
      "adapter_type": "modbus_rtu",
      "config": {
        "serial_port": "rtu://plant-simulator:16020",
        "baudrate": 19200,
        "bytesize": 8,
        "parity": "N",
        "stopbits": 1,
        "timeout": 1,
        "unit_id": 11,
        "poll_interval_ms": 1000,
        "points": [
          {
            "point_name": "remote_tank_level_pct",
            "memory_area": "holding_register",
            "address": 40001,
            "data_type": "uint16",
            "scale": 0.1,
            "unit": "%",
            "classification": "telemetry"
          },
          {
            "point_name": "remote_valve_position_pct",
            "memory_area": "holding_register",
            "address": 40002,
