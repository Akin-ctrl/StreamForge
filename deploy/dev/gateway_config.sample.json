        "baudrate": 19200,
        "bytesize": 8,
        "parity": "N",
        "stopbits": 1,
        "timeout": 1,
        "unit_id": 21,
        "poll_interval_ms": 1000,
        "points": [
          {
            "point_name": "line_voltage",
            "memory_area": "holding_register",
            "address": 40001,
            "data_type": "uint16",
            "scale": 0.1,
            "unit": "V",
            "classification": "telemetry"
          },
          {
            "point_name": "line_current",
            "memory_area": "holding_register",
            "address": 40002,
